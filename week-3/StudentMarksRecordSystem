# Student Marks Record Program
marks = []

n = int(input("Enter number of students: "))

for i in range(n):
    mark = float(input(f"Enter marks for student {i+1}: "))
    marks.append(mark)  # ArrayList me store

if marks:
    highest = max(marks)
    lowest = min(marks)
    print("\n--- Results ---")
    print(f"Highest Marks: {highest}")
    print(f"Lowest Marks: {lowest}")
    print(f"All Marks: {marks}")
else:
    print("No marks entered")
